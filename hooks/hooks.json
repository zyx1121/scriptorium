{
  "description": "scriptorium engine — Scribe observation + method router + Corrector trigger + Armarium memory-sync, wired to the Claude Code lifecycle.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "echo 'Method router (/method) active. Before any non-trivial coding/decision task, invoke the method skill FIRST to classify and emit [METHOD: <name>]. Trivial single-action tasks fall through silently.'" },
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scribe/events.py\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill|Agent|Task",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scribe/events.py\"" }
        ]
      },
      {
        "matcher": "Write|Bash",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scribe/observe.py\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scribe/events.py\"" },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/armarium/memory-sync.sh\"" },
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/armarium/otel_sync.py\"" }
        ]
      }
    ]
  }
}
