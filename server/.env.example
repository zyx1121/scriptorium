# --- Database ---
# Postgres connection string. The docker-compose service name is `db`.
DATABASE_URL=postgres://scriptorium:scriptorium@db:5432/scriptorium

# --- HTTP server ---
PORT=8787
# Public base URL (used for self-references in responses, e.g. /whoami)
PUBLIC_URL=https://wiki.your-team.tld

# --- Auth ---
# Admin token used by the CLI for token issuance. Generate a long random string.
ADMIN_TOKEN=replace-me-with-openssl-rand-base64-32

# --- Logging ---
LOG_LEVEL=info
